{
  "name": "@agent-desk/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -b",
    "postbuild": "node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/hooks',{recursive:true});cpSync('src/hooks','dist/hooks',{recursive:true})\"",
    "start": "node dist/main.js",
    "lint": "echo 'no lint yet'",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@agent-desk/shared": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.19",
    "node-pty": "^1.1.0",
    "smol-toml": "^1.6.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.41",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
